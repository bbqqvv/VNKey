<Window x:Class="VNKey.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation/shell"
        xmlns:vm="clr-namespace:VNKey.Windows.ViewModels"
        xmlns:conv="clr-namespace:VNKey.Windows.Converters"
        xmlns:ctrl="clr-namespace:VNKey.Windows.Controls"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="VNKey" Height="410" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/VNKey.png">

    <Window.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
            <conv:InputModeToIndexConverter x:Key="InputModeToIndexConverter"/>
            <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>

            <!-- Sidebar Nav Button -->
            <Style x:Key="NavButtonStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Margin="4,2" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource AppBorder}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource AppControlBackground}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="LogoButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        <!-- Card style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>


        <!-- DataGrid Styling -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppAlternatingRow}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryText}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccent}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AppAccentForeground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="RadioButton" x:Key="StandardRadioButton">
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

    </ResourceDictionary>
</Window.Resources>

    <Border Background="{DynamicResource AppBackground}" CornerRadius="8" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
            TextElement.Foreground="{DynamicResource AppText}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition x:Name="RowHorizontalNav" Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent" Cursor="Hand">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Button Command="{Binding ToggleSidebarCommand}" Style="{StaticResource LogoButtonStyle}" Margin="0,0,10,0" ToolTip="Thu gọn/Mở rộng bảng điều khiển">
                        <TextBlock x:Name="LogoIcon" Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AppAccent}" FontSize="18" VerticalAlignment="Center"/>
                    </Button>
                    <TextBlock Text="VNKey" FontWeight="Bold" Foreground="{DynamicResource AppText}" FontSize="14" VerticalAlignment="Center" 
                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text=" 2.0" Foreground="{DynamicResource AppSecondaryText}" FontSize="14" VerticalAlignment="Center" 
                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Width="36" Height="34" Background="Transparent" BorderThickness="0" Command="{Binding ToggleThemeCommand}" Cursor="Arrow">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="{DynamicResource AppSecondaryText}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}">
                                                <TextBlock x:Name="icon" Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Chuyển chế độ Sáng/Tối"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource AppBorder}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsDarkMode}" Value="False">
                                                    <Setter TargetName="icon" Property="Text" Value="&#xE708;" /> <!-- Moon icon for Light Mode (to switch to dark) -->
                                                    <Setter TargetName="icon" Property="Foreground" Value="#D4A017" /> <!-- Golden Moon -->
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                    <Setter TargetName="icon" Property="Text" Value="&#xE706;" /> <!-- Sun icon for Dark Mode (to switch to light) -->
                                                    <Setter TargetName="icon" Property="Foreground" Value="#FFCC00" /> <!-- Golden Sun -->
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Width="36" Height="34" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppSecondaryText}" Click="CloseButton_Click" Cursor="Arrow">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ═══ Horizontal Nav Bar ═══ -->
            <Border x:Name="HorizontalNavBorder" Grid.Row="1" Height="40" Background="{DynamicResource AppSidebarBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1" Visibility="{Binding IsNavVertical, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Padding="10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Mode indicator (Parity with Sidebar) -->
                    <Border Background="{DynamicResource AppControlBackground}" CornerRadius="6" Margin="0,0,15,0" Padding="8,2">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton GroupName="ModeH" IsChecked="{Binding IsVietnameseMode}" Margin="0,0,8,0">
                                <TextBlock Text="VN" FontSize="10" FontWeight="Bold"/>
                            </RadioButton>
                            <RadioButton GroupName="ModeH" IsChecked="{Binding IsVietnameseMode, Converter={StaticResource InverseBooleanConverter}, FallbackValue=False}">
                                <TextBlock Text="EN" FontSize="10" FontWeight="Bold"/>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Input}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="Input" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Bộ gõ" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Shorthand}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="Shorthand" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Gõ tắt" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=System}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="System" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Hệ thống" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=About}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="About" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Thông tin" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Diagnostics}" GroupName="NavH" Visibility="{Binding IsDevModeEnabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Command="{Binding NavigateCommand}" CommandParameter="Diagnostics">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource AppAccent}"/>
                            <TextBlock Text="Dev Mode" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource AppAccent}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ═══ Main Content: Sidebar + Pages ═══ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ColSidebar" Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border x:Name="SidebarBorder" Grid.Column="0" Background="{DynamicResource AppSidebarBackground}" CornerRadius="0,0,0,8" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,1,0" 
                        Visibility="{Binding IsNavVertical, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <Setter Property="Width" Value="140"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="Width" Value="48"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel x:Name="NavButtonsStack" Margin="0,5" Orientation="Vertical">
                        <!-- Mode indicator -->
                        <Border x:Name="SideModeIndicator" Background="{DynamicResource AppControlBackground}" CornerRadius="6" Margin="10,0,10,8" Padding="10,2"
                                Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Chế độ" FontSize="10" Foreground="{DynamicResource AppSecondaryText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton GroupName="Mode" IsChecked="{Binding IsVietnameseMode}" Margin="0,0,8,0">
                                        <TextBlock Text="VN" FontSize="11" FontWeight="Bold"/>
                                    </RadioButton>
                                    <RadioButton GroupName="Mode" IsChecked="{Binding IsVietnameseMode, Converter={StaticResource InverseBooleanConverter}, FallbackValue=False}">
                                        <TextBlock Text="EN" FontSize="11" FontWeight="Bold"/>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Navigation buttons -->
                        <RadioButton x:Name="NavInput" Style="{StaticResource NavButtonStyle}" IsChecked="True" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="Input">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Bộ gõ" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                        <RadioButton x:Name="NavShorthand" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="Shorthand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Gõ tắt" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                        <RadioButton x:Name="NavSystem" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="System">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Hệ thống" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                        <RadioButton x:Name="NavAbout" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="About">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Thông tin" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="NavDiagnostics" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Visibility="{Binding IsDevModeEnabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Command="{Binding NavigateCommand}" CommandParameter="Diagnostics">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppAccent}"/>
                                <TextBlock Grid.Column="1" Text="Dev Mode" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource AppAccent}"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- RIGHT CONTENT AREA -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="18,6,18,6">

                        <!-- ═══ PAGE: Tiếng Việt ═══ -->
                        <StackPanel x:Name="PageInput">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Input">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Bộ gõ" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

                            <!-- Card: Input Method -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="PHƯƠNG THỨC NHẬP" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Kiểu gõ" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                         <ComboBox Grid.Column="1" SelectedIndex="{Binding CurrentInputMode, Converter={StaticResource InputModeToIndexConverter}}" Height="26" ToolTip="Chọn quy tắc gõ tiếng Việt (Telex, VNI, VIQR). Telex là kiểu gõ phổ biến nhất.">
                                            <ComboBoxItem Content="Telex"/>
                                            <ComboBoxItem Content="VNI"/>
                                            <ComboBoxItem Content="VIQR"/>
                                            <ComboBoxItem Content="TelexEx"/>
                                        </ComboBox>
                                        <TextBlock Text="Bảng mã" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Grid.Column="4" SelectedIndex="0" Height="26" ToolTip="Bảng mã ký tự xuất ra. Unicode là chuẩn hiện đại tương thích với hầu hết ứng dụng.">
                                            <ComboBoxItem Content="Unicode"/>
                                            <ComboBoxItem Content="TCVN3"/>
                                            <ComboBoxItem Content="VNI Windows"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Card: Smart Features -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="TÍNH NĂNG THÔNG MINH" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,8"/>
                                     <CheckBox IsChecked="{Binding ModernTone}" Content="Đặt dấu oà, uý (thay vì òa, úy)" ToolTip="Đặt dấu trên nguyên âm chính xác hơn (Ví dụ: hoành tráng (oà) vs hoành tráng (òa))."/>
                                     <CheckBox IsChecked="{Binding AutoCapitalizeSentence}" Content="Tự động viết hoa sau dấu chấm (., ?, !)" ToolTip="Tự động viết hoa chữ cái đầu tiên sau các dấu kết thúc câu (. ? !). Ví dụ: Chào bạn. Bạn khỏe không?"/>
                                     <CheckBox IsChecked="{Binding AutoCapitalizeEnter}" Content="Tự động viết hoa sau khi nhấn Enter" ToolTip="Tự động viết hoa chữ cái đầu tiên khi bạn nhấn Enter để xuống dòng mới."/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Spell Check -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="CHÍNH TẢ VÀ KHÔI PHỤC" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,8"/>
                                     <CheckBox IsChecked="{Binding SpellCheck}" Content="Kiểm tra chính tả" ToolTip="Ngăn chặn các tổ hợp vần lạ không tồn tại trong tiếng Việt (Ví dụ: qqw, hhh)."/>
                                     <CheckBox IsChecked="{Binding AutoRestore}" Content="Tự khôi phục phím với từ sai" ToolTip="Tự động trả lại các phím gốc nếu bạn gõ một từ sai chính tả hoặc sai quy tắc gõ."/>
                                     <CheckBox IsChecked="{Binding SmartLiteralMode}" Content="Tự động nhận diện tiếng Anh/Từ dài" ToolTip="Tự động nhận diện khi gõ tiếng Anh hoặc chuỗi dài (code, mật khẩu) để không bỏ dấu nhầm. Tắt nếu muốn gõ chuỗi dài vô tận."/>
                                     <CheckBox IsChecked="{Binding AllowForeignConsonants}" Content="Cho phép 'z w j f' làm phụ âm" ToolTip="Cho phép các phím z, w, j, f đứng ở đầu từ (Ví dụ: zui zẻ, win-win)."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ PAGE: Gõ tắt ═══ -->
                        <StackPanel x:Name="PageShorthand">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Shorthand">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Gõ tắt" FontSize="18" FontWeight="Bold"/>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{DynamicResource AppControlBackground}" CornerRadius="6" Padding="6,1" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource AppSecondaryText}" VerticalAlignment="Center" Margin="2,0,8,0" Opacity="0.5"/>
                                        <TextBox Width="100" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppText}" FontSize="12" VerticalContentAlignment="Center" MaxLength="20" Text="{Binding ShorthandSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Quick Add Area -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Row 0: Labels -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="VIẾT TẮT" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource AppSecondaryText}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="THAY THẾ" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource AppSecondaryText}" Margin="0,0,0,4"/>
                                        
                                        <!-- Row 1: Controls -->
                                        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewMacro, UpdateSourceTrigger=PropertyChanged}" Height="22" VerticalContentAlignment="Center" Padding="5,0"/>
                                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding NewExpansion, UpdateSourceTrigger=PropertyChanged}" Height="22" VerticalContentAlignment="Center" Padding="5,0"/>
                                        <Button Grid.Row="1" Grid.Column="3" Content="Thêm" Command="{Binding AddShorthandCommand}" Style="{StaticResource AccentButtonStyle}" FontWeight="SemiBold" Width="60" Height="22" Margin="10,0,0,0" Padding="0"/>
                                    </Grid>
                            </Border>

                            <!-- Main Table Area -->
                            <Border Style="{StaticResource CardStyle}" Padding="0" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="180"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DataGrid Grid.Row="0" 
                                              ItemsSource="{Binding FilteredShorthandList}"
                                              AutoGenerateColumns="False" 
                                              Background="Transparent" 
                                              BorderThickness="0"
                                              HeadersVisibility="Column"
                                              RowHeight="28">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="VIẾT TẮT" Binding="{Binding Macro}" Width="100" IsReadOnly="True" />
                                            <DataGridTextColumn Header="THAY THẾ BẰNG" Binding="{Binding Expansion}" Width="*" IsReadOnly="True" />
                                            <DataGridTemplateColumn Width="32">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                                                                Background="Transparent" BorderThickness="0" 
                                                                Foreground="#FF4444" FontSize="11"
                                                                Command="{Binding DataContext.DeleteShorthandCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                Cursor="Hand"
                                                                ToolTip="Xóa mục này"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    
                                    <!-- Options & Import/Export -->
                                    <Border Grid.Row="1" Background="{DynamicResource AppControlBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="12,8" CornerRadius="0,0,8,8">
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding ShorthandWhileOff}" Content="Gõ tắt khi tắt TV" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="10.5" ToolTip="Vẫn áp dụng các từ gõ tắt ngay cả khi bạn đang tắt chế độ gõ tiếng Việt."/>
                                                <CheckBox IsChecked="{Binding ShorthandAutoCase}" Content="Tự động hoa/thường" VerticalAlignment="Center" FontSize="10.5" ToolTip="Tự động điều chỉnh viết hoa từ thay thế dựa trên cách bạn gõ từ viết tắt (Ví dụ: ko -> không, Ko -> Không)."/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="Nhập File" Command="{Binding ImportShorthandCommand}" Style="{StaticResource AppButtonStyle}" Padding="10,2" FontSize="10" Margin="0,0,8,0"/>
                                                <Button Content="Xuất File" Command="{Binding ExportShorthandCommand}" Style="{StaticResource AppButtonStyle}" Padding="10,2" FontSize="10"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ═══ PAGE: Hệ thống ═══ -->
                        <StackPanel x:Name="PageSystem">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="System">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Hệ thống" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

                            <!-- Card: Giao diện -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="GIAO DIỆN" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <RadioButton IsChecked="{Binding IsNavVertical}" Content="Menu dọc (trái)" GroupName="UINavLayout" Margin="0,0,15,0"/>
                                        <RadioButton IsChecked="{Binding IsNavVertical, Converter={StaticResource InverseBooleanConverter}}" Content="Menu ngang (trên)" GroupName="UINavLayout"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Card: Phím tắt -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="PHÍM TẮT CHUYỂN NGÔN NGỮ" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                        <RadioButton Content="Alt + Z" IsChecked="{Binding SwitchShortcut, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Alt+Z'}" GroupName="UIHotkey" Margin="0,0,15,0" ToolTip="Sử dụng Alt + Z."/>
                                        <RadioButton Content="Ctrl + Shift" IsChecked="{Binding SwitchShortcut, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Ctrl+Shift'}" GroupName="UIHotkey" Margin="0,0,15,0" ToolTip="Sử dụng Ctrl + Shift."/>
                                        <RadioButton x:Name="RbHotkeyCustom" Content="Tùy chỉnh:" IsChecked="{Binding SwitchShortcut, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Custom'}" GroupName="UIHotkey" Margin="0,0,5,0" ToolTip="Tự cài đặt phím tắt theo ý muốn."/>
                                        <TextBlock Text="{Binding CustomShortcut}" Foreground="{DynamicResource AppAccent}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=RbHotkeyCustom, Path=IsChecked}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Command="{Binding RecordShortcutCommand}" Padding="8,2" FontSize="10" IsEnabled="{Binding ElementName=RbHotkeyCustom, Path=IsChecked}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecordingShortcut}" Value="True">
                                                            <Setter Property="Content" Value="Bấm phím..."/>
                                                            <Setter Property="Background" Value="{DynamicResource AppAccent}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRecordingShortcut}" Value="False">
                                                            <Setter Property="Content" Value="Ghi phím"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding BeepOnModeChange}" Content="Kêu beep khi chuyển ngôn ngữ" ToolTip="Phát âm thanh bíp ngắn khi bạn chuyển đổi giữa chế độ gõ Tiếng Việt và Tiếng Anh."/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Startup -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding IsRunAtStartup}" Content="Khởi động cùng Windows (Beta)" ToolTip="VNKey sẽ tự động khởi chạy cùng Windows mỗi khi bạn mở máy."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="PageDiagnostics">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Diagnostics">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ctrl:DiagnosticsControl DataContext="{Binding Diagnostics}" Visibility="{Binding Diagnostics.IsPopOut, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            <Border Visibility="{Binding Diagnostics.IsPopOut, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource CardStyle}" BorderBrush="{DynamicResource AppAccent}" BorderThickness="1" Height="200" VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{DynamicResource AppSecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="Đang hiển thị trong cửa sổ riêng." FontSize="11" Foreground="{DynamicResource AppSecondaryText}" HorizontalAlignment="Center"/>
                                    <Button Content="Gắn lại bảng điều khiển" Command="{Binding ReturnDiagnosticsCommand}" Style="{StaticResource AccentButtonStyle}" Margin="0,15,0,0" Width="180"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ PAGE: Thông tin ═══ -->
                        <StackPanel x:Name="PageAbout">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Thông tin" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                            
                            <Border Style="{StaticResource CardStyle}" Padding="25">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Header with Logo -->
                                        <RowDefinition Height="Auto"/> <!-- Description -->
                                        <RowDefinition Height="Auto"/> <!-- Resources -->
                                        <RowDefinition Height="Auto"/> <!-- Footer -->
                                    </Grid.RowDefinitions>

                                    <!-- Top Section: Logo & Brand -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                                        <Border Width="64" Height="64" Background="{DynamicResource AppControlBackground}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Margin="0,0,20,0">
                                            <Image Source="/Assets/VNKey.png" Margin="10"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="VNKey" FontSize="28" FontWeight="ExtraBold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Phiên bản 2.0.0 Stable" FontSize="12" Foreground="{DynamicResource AppSecondaryText}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Description Area -->
                                    <Border Grid.Row="1" Background="{DynamicResource AppBackground}" CornerRadius="6" Padding="15" Margin="0,0,0,25">
                                        <TextBlock Text="Bộ gõ tiếng Việt thế hệ mới với hiệu năng cao, mã nguồn mở và khả năng tùy biến tuyệt vời. Được thiết kế để mang lại trải nghiệm gõ mượt mà và thông minh nhất trên Windows." 
                                                   TextWrapping="Wrap" FontSize="12" LineHeight="18" Foreground="{DynamicResource AppText}" Opacity="0.9"/>
                                    </Border>

                                    <!-- Resource Links -->
                                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                                        <TextBlock Text="TÀI NGUYÊN &amp; CỘNG ĐỒNG" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource AppSecondaryText}" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- GitHub Link -->
                                            <Button Cursor="Hand" Background="Transparent" BorderThickness="0" Margin="0,0,20,0" ToolTip="GitHub Repository">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xEC40;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccent}"/>
                                                    <TextBlock Text="Mã nguồn GitHub" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource AppText}"/>
                                                </StackPanel>
                                            </Button>
                                            <!-- Website Link -->
                                            <Button Cursor="Hand" Background="Transparent" BorderThickness="0" Margin="0,0,20,0" ToolTip="Official Website">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccent}"/>
                                                    <TextBlock Text="Trang chủ" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource AppText}"/>
                                                </StackPanel>
                                            </Button>
                                            <!-- Issues Link -->
                                            <Button Cursor="Hand" Background="Transparent" BorderThickness="0" ToolTip="Report Issues">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE939;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccent}"/>
                                                    <TextBlock Text="Báo lỗi" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource AppText}"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Footer info -->
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                                        <Grid>
                                            <TextBlock Text="© 2024 VNKDEV. Bảo lưu mọi quyền." FontSize="10" Foreground="{DynamicResource AppSecondaryText}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Phát triển với ❤️ tại Việt Nam" HorizontalAlignment="Right" FontSize="10" Foreground="{DynamicResource AppSecondaryText}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ═══ Bottom Bar ═══ -->
            <Grid Grid.Row="3" Margin="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding ResetCommand}" Style="{DynamicResource AppButtonStyle}" Width="95" Height="28" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="-1" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="Mặc định" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource AppButtonStyle}" Width="80" Height="28" Click="ExitButton_Click" Margin="0,0,8,0">
                        <TextBlock Text="Thoát" FontSize="11" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}" Width="80" Height="28" Click="CloseButton_Click">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đóng" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
