<Window x:Class="VNKey.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation/shell"
        xmlns:vm="clr-namespace:VNKey.Windows.ViewModels"
        xmlns:conv="clr-namespace:VNKey.Windows.Converters"
        xmlns:ctrl="clr-namespace:VNKey.Windows.Controls"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="VNKey" Height="420" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        PreviewMouseDown="Window_PreviewMouseDown"
        Icon="/Assets/VNKey.png">

    <Window.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
            <conv:InputModeToIndexConverter x:Key="InputModeToIndexConverter"/>
            <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>

            <!-- Sidebar Nav Button -->
            <Style x:Key="NavButtonStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                <Setter Property="Padding" Value="0,4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Margin="13,2" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource AppBorder}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource AppControlBackground}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="LogoButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        <!-- Card style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>


        <!-- DataGrid Styling -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppAlternatingRow}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryText}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccent}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AppAccentForeground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="RadioButton" x:Key="StandardRadioButton">
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

    </ResourceDictionary>
</Window.Resources>

    <Border Background="{DynamicResource AppBackground}" CornerRadius="8" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
            TextElement.Foreground="{DynamicResource AppText}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition x:Name="RowHorizontalNav" Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent" Cursor="Hand">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="13,0">
                    <Button Command="{Binding ToggleSidebarCommand}" Style="{StaticResource LogoButtonStyle}" Margin="0" ToolTip="Thu gọn/Mở rộng bảng điều khiển">
                        <Grid Width="24">
                            <TextBlock x:Name="LogoIcon" Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AppAccent}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                    <TextBlock Text="VNKey" FontWeight="Bold" Foreground="{DynamicResource AppText}" FontSize="15" VerticalAlignment="Center" 
                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text=" 2.0" Foreground="{DynamicResource AppSecondaryText}" FontSize="15" VerticalAlignment="Center" 
                               Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Width="36" Height="34" Background="Transparent" BorderThickness="0" Command="{Binding ToggleThemeCommand}" Cursor="Arrow">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="{DynamicResource AppSecondaryText}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}">
                                                <TextBlock x:Name="icon" Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Chuyển chế độ Sáng/Tối"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource AppBorder}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsDarkMode}" Value="False">
                                                    <Setter TargetName="icon" Property="Text" Value="&#xE708;" /> <!-- Moon icon for Light Mode (to switch to dark) -->
                                                    <Setter TargetName="icon" Property="Foreground" Value="#D4A017" /> <!-- Golden Moon -->
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                    <Setter TargetName="icon" Property="Text" Value="&#xE706;" /> <!-- Sun icon for Dark Mode (to switch to light) -->
                                                    <Setter TargetName="icon" Property="Foreground" Value="#FFCC00" /> <!-- Golden Sun -->
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Width="36" Height="34" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppSecondaryText}" Click="CloseButton_Click" Cursor="Arrow">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ═══ Horizontal Nav Bar ═══ -->
            <Border x:Name="HorizontalNavBorder" Grid.Row="1" Height="44" Background="{DynamicResource AppSidebarBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1" Visibility="{Binding IsNavVertical, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Padding="10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Mode indicator (Parity with Sidebar) -->
                    <Border Background="{DynamicResource AppControlBackground}" CornerRadius="6" Margin="0,0,15,0" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton GroupName="ModeH" IsChecked="{Binding IsVietnameseMode}" Margin="0,0,8,0">
                                <TextBlock Text="VN" FontSize="12" FontWeight="Bold"/>
                            </RadioButton>
                            <RadioButton GroupName="ModeH" IsChecked="{Binding IsVietnameseMode, Converter={StaticResource InverseBooleanConverter}, FallbackValue=False}">
                                <TextBlock Text="EN" FontSize="12" FontWeight="Bold"/>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Input}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="Input" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Bộ gõ" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Shorthand}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="Shorthand" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Gõ tắt" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=System}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="System" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Hệ thống" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=About}" GroupName="NavH" Command="{Binding NavigateCommand}" CommandParameter="About" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Thông tin" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Diagnostics}" GroupName="NavH" Visibility="{Binding IsDevModeEnabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Command="{Binding NavigateCommand}" CommandParameter="Diagnostics">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource AppAccent}"/>
                            <TextBlock Text="Dev Mode" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource AppAccent}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ═══ Main Content: Sidebar + Pages ═══ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ColSidebar" Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border x:Name="SidebarBorder" Grid.Column="0" Background="{DynamicResource AppSidebarBackground}" CornerRadius="0,0,0,8" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,1,0" 
                        Visibility="{Binding IsNavVertical, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                    <Setter Property="Width" Value="160"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="Width" Value="50"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel x:Name="NavButtonsStack" Margin="0,5" Orientation="Vertical">
                        <!-- Mode indicator -->
                        <Border x:Name="SideModeIndicator" Background="{DynamicResource AppControlBackground}" CornerRadius="6" Margin="13,0,13,8" Padding="12,6"
                                Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Chế độ" FontSize="10" Foreground="{DynamicResource AppSecondaryText}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton GroupName="Mode" IsChecked="{Binding IsVietnameseMode}" Margin="0,0,8,0">
                                        <TextBlock Text="VN" FontSize="11" FontWeight="Bold"/>
                                    </RadioButton>
                                    <RadioButton GroupName="Mode" IsChecked="{Binding IsVietnameseMode, Converter={StaticResource InverseBooleanConverter}, FallbackValue=False}">
                                        <TextBlock Text="EN" FontSize="11" FontWeight="Bold"/>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Navigation buttons -->
                        <RadioButton x:Name="NavInput" Style="{StaticResource NavButtonStyle}" IsChecked="True" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="Input">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Bộ gõ" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                        <RadioButton x:Name="NavShorthand" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="Shorthand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Gõ tắt" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                        <RadioButton x:Name="NavSystem" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="System">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Hệ thống" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                        <RadioButton x:Name="NavAbout" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Command="{Binding NavigateCommand}" CommandParameter="About">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Thông tin" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="NavDiagnostics" Style="{StaticResource NavButtonStyle}" GroupName="Nav" Visibility="{Binding IsDevModeEnabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Command="{Binding NavigateCommand}" CommandParameter="Diagnostics">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppAccent}"/>
                                <TextBlock Grid.Column="1" Text="Dev Mode" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource AppAccent}"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- RIGHT CONTENT AREA -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="12,6,12,6">

                        <!-- ═══ PAGE: Tiếng Việt ═══ -->
                        <StackPanel x:Name="PageInput">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Input">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Bộ gõ" FontSize="17" FontWeight="Bold" Margin="0,0,0,8"/>

                            <!-- Card: Input Method -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="PHƯƠNG THỨC NHẬP" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Kiểu gõ" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                         <ComboBox Grid.Column="1" SelectedIndex="{Binding CurrentInputMode, Converter={StaticResource InputModeToIndexConverter}}" Height="26" ToolTip="Chọn quy tắc gõ tiếng Việt (Telex, VNI, VIQR). Telex là kiểu gõ phổ biến nhất.">
                                            <ComboBoxItem Content="Telex"/>
                                            <ComboBoxItem Content="VNI"/>
                                            <ComboBoxItem Content="VIQR"/>
                                            <ComboBoxItem Content="TelexEx"/>
                                        </ComboBox>
                                        <TextBlock Text="Bảng mã" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Grid.Column="4" SelectedIndex="0" Height="26" ToolTip="Bảng mã ký tự xuất ra. Unicode là chuẩn hiện đại tương thích với hầu hết ứng dụng.">
                                            <ComboBoxItem Content="Unicode"/>
                                            <ComboBoxItem Content="TCVN3"/>
                                            <ComboBoxItem Content="VNI Windows"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Card: Smart Features -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="TÍNH NĂNG THÔNG MINH" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,8"/>
                                     <CheckBox IsChecked="{Binding ModernTone}" Content="Đặt dấu oà, uý (thay vì òa, úy)" ToolTip="Đặt dấu trên nguyên âm chính xác hơn (Ví dụ: hoành tráng (oà) vs hoành tráng (òa))."/>
                                     <CheckBox IsChecked="{Binding AutoCapitalizeSentence}" Content="Tự động viết hoa sau dấu chấm (., ?, !)" ToolTip="Tự động viết hoa chữ cái đầu tiên sau các dấu kết thúc câu (. ? !). Ví dụ: Chào bạn. Bạn khỏe không?"/>
                                     <CheckBox IsChecked="{Binding AutoCapitalizeEnter}" Content="Tự động viết hoa sau khi nhấn Enter" ToolTip="Tự động viết hoa chữ cái đầu tiên khi bạn nhấn Enter để xuống dòng mới."/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Spell Check -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="CHÍNH TẢ VÀ KHÔI PHỤC" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,6"/>
                                     <CheckBox IsChecked="{Binding SpellCheck}" Content="Kiểm tra chính tả" ToolTip="Ngăn chặn các tổ hợp vần lạ không tồn tại trong tiếng Việt (Ví dụ: qqw, hhh)."/>
                                     <CheckBox IsChecked="{Binding AutoRestore}" Content="Tự khôi phục phím với từ sai" ToolTip="Tự động trả lại các phím gốc nếu bạn gõ một từ sai chính tả hoặc sai quy tắc gõ."/>
                                     <CheckBox IsChecked="{Binding SmartLiteralMode}" Content="Tự động nhận diện tiếng Anh/Từ dài" ToolTip="Tự động nhận diện khi gõ tiếng Anh hoặc chuỗi dài (code, mật khẩu) để không bỏ dấu nhầm. Tắt nếu muốn gõ chuỗi dài vô tận."/>
                                     <CheckBox IsChecked="{Binding AllowForeignConsonants}" Content="Cho phép 'z w j f' làm phụ âm" ToolTip="Cho phép các phím z, w, j, f đứng ở đầu từ (Ví dụ: zui zẻ, win-win)."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ PAGE: Gõ tắt ═══ -->
                        <StackPanel x:Name="PageShorthand">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Shorthand">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Gõ tắt" FontSize="19" FontWeight="Bold" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="Mẫu gõ tắt" Click="TemplateButton_Click" Style="{StaticResource AppButtonStyle}" Padding="8,1" FontSize="10" Margin="0,0,6,0" FontWeight="SemiBold" Height="24">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Tải lại danh sách mẫu" Command="{Binding RefreshTemplatesCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE149;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Chỉnh sửa mẫu..." Command="{Binding OpenTemplatesCommand}" ToolTip="Mở thư mục chứa các mẫu để tùy chỉnh">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Thêm từ mẫu có sẵn" ItemsSource="{Binding BuiltInTemplates}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Header" Value="{Binding Name}"/>
                                                            <Setter Property="Command" Value="{Binding DataContext.ApplyTemplateCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <Setter Property="CommandParameter" Value="{Binding}"/>
                                                            <Setter Property="ToolTip" Value="{Binding Description}"/>
                                                            <Setter Property="Icon">
                                                                <Setter.Value>
                                                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <Button Content="Nhập" Command="{Binding ImportShorthandCommand}" Style="{StaticResource AppButtonStyle}" Padding="8,1" FontSize="10" Margin="0,0,6,0" ToolTip="Nhập danh sách từ file JSON" Height="24"/>
                                    <Button Content="Xuất" Command="{Binding ExportShorthandCommand}" Style="{StaticResource AppButtonStyle}" Padding="8,1" FontSize="10" Margin="0,0,6,0" ToolTip="Xuất danh sách ra file JSON" Height="24"/>
                                    
                                    <Border x:Name="SearchBorder" Background="{DynamicResource AppControlBackground}" CornerRadius="6" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Margin="0,0,0,0" Height="24" Width="26" ClipToBounds="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <ToggleButton x:Name="SearchToggle" Cursor="Hand" ToolTip="Tìm kiếm" Checked="SearchToggle_Checked" Unchecked="SearchToggle_Unchecked">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent">
                                                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource AppSecondaryText}" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.8"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                                <ToggleButton.Triggers>
                                                    <EventTrigger RoutedEvent="ToggleButton.Checked">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="SearchBorder" Storyboard.TargetProperty="Width" To="140" Duration="0:0:0.25">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="SearchBorder" Storyboard.TargetProperty="Width" To="26" Duration="0:0:0.25">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </ToggleButton.Triggers>
                                            </ToggleButton>
                                            
                                            <TextBox x:Name="SearchTextBox" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AppText}" FontSize="11.5" VerticalContentAlignment="Center" MaxLength="20" Text="{Binding ShorthandSearchText, UpdateSourceTrigger=PropertyChanged}" Padding="2,0,5,0" Margin="0"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Integrated Quick Add Row -->
                            <Border Style="{StaticResource CardStyle}" Padding="0,6" Margin="0,0,0,8" Background="Transparent" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Labels -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="VIẾT TẮT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AppSecondaryText}" Margin="2,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="THAY THẾ BẰNG" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AppSecondaryText}" Margin="2,0,0,4"/>
                                    
                                    <Grid Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="VD: vn" Foreground="{DynamicResource AppSecondaryText}" FontSize="11" VerticalAlignment="Center" Margin="8,0" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NewMacro.Length}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NewMacro}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding NewMacro, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center" Padding="5,0" FontSize="11.5" Background="{DynamicResource AppInputBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"/>
                                    </Grid>
                                    
                                    <!-- Arrow -->
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource AppSecondaryText}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    
                                    <Grid Grid.Row="1" Grid.Column="2">
                                        <TextBlock Text="VD: Việt Nam" Foreground="{DynamicResource AppSecondaryText}" FontSize="11" VerticalAlignment="Center" Margin="8,0" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NewExpansion.Length}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding NewExpansion}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding NewExpansion, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center" Padding="5,0" FontSize="11.5" Background="{DynamicResource AppInputBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"/>
                                    </Grid>
                                    
                                    <Button Grid.Row="1" Grid.Column="4" Command="{Binding AddShorthandCommand}" Style="{StaticResource AccentButtonStyle}" FontWeight="SemiBold" Width="95" Height="26" Padding="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Thêm mới" FontSize="10.5" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Main Table Area -->
                            <Border Style="{StaticResource CardStyle}" Padding="0" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="240"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DataGrid Grid.Row="0" 
                                              ItemsSource="{Binding FilteredShorthandList}"
                                              AutoGenerateColumns="False" 
                                              Background="Transparent" 
                                              BorderThickness="0"
                                              HeadersVisibility="Column"
                                              RowHeight="24">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="VIẾT TẮT" Binding="{Binding Macro}" Width="100" IsReadOnly="True" />
                                            <DataGridTextColumn Header="THAY THẾ BẰNG" Binding="{Binding Expansion}" Width="*" IsReadOnly="True" />
                                            <DataGridTemplateColumn Width="32">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                                                                Background="Transparent" BorderThickness="0" 
                                                                Foreground="#FF4444" FontSize="11"
                                                                Command="{Binding DataContext.DeleteShorthandCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                Cursor="Hand"
                                                                ToolTip="Xóa mục này"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    
                                    <Border Grid.Row="1" Background="{DynamicResource AppControlBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="15,10" CornerRadius="0,0,10,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding ShorthandWhileOff}" Content="Gõ tắt khi tắt Tiếng Việt" VerticalAlignment="Center" FontSize="11"/>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding ShorthandAutoCase}" Content="Tự động hoa/thường" VerticalAlignment="Center" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ═══ PAGE: Hệ thống ═══ -->
                        <StackPanel x:Name="PageSystem">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="System">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Hệ thống" FontSize="17" FontWeight="Bold" Margin="0,0,0,6"/>

                            <Border Style="{StaticResource CardStyle}">
                                <CheckBox IsChecked="{Binding PlaySoundOnAction}" Content="Phát âm thanh khi thay đổi thiết lập" FontSize="11"/>
                            </Border>

                            <!-- Card: Giao diện -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="GIAO DIỆN" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton IsChecked="{Binding IsNavVertical}" Content="Menu dọc" GroupName="UINavLayout" Margin="0,0,12,0" FontSize="10.5"/>
                                        <RadioButton IsChecked="{Binding IsNavVertical, Converter={StaticResource InverseBooleanConverter}}" Content="Menu ngang" GroupName="UINavLayout" FontSize="10.5"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Card: Phím tắt -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="PHÍM TẮT CHUYỂN NGÔN NGỮ" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <RadioButton Content="Alt + Z" IsChecked="{Binding SwitchShortcut, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Alt+Z'}" GroupName="UIHotkey" Margin="0,0,12,0" FontSize="11"/>
                                        <RadioButton Content="Ctrl + Shift" IsChecked="{Binding SwitchShortcut, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Ctrl+Shift'}" GroupName="UIHotkey" Margin="0,0,12,0" FontSize="11"/>
                                        <RadioButton x:Name="RbHotkeyCustom" Content="Tùy chỉnh:" IsChecked="{Binding SwitchShortcut, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter='Custom'}" GroupName="UIHotkey" Margin="0,0,4,0" FontSize="11"/>
                                        <TextBlock Text="{Binding CustomShortcut}" Foreground="{DynamicResource AppAccent}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=RbHotkeyCustom, Path=IsChecked}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Command="{Binding RecordShortcutCommand}" Padding="8,2" FontSize="10" IsEnabled="{Binding ElementName=RbHotkeyCustom, Path=IsChecked}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecordingShortcut}" Value="True">
                                                            <Setter Property="Content" Value="Bấm phím..."/>
                                                            <Setter Property="Background" Value="{DynamicResource AppAccent}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRecordingShortcut}" Value="False">
                                                            <Setter Property="Content" Value="Ghi phím"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding BeepOnModeChange}" Content="Kêu beep khi chuyển ngôn ngữ" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Startup -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding IsRunAtStartup}" Content="Khởi động cùng Windows" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="PageDiagnostics">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Diagnostics">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ctrl:DiagnosticsControl DataContext="{Binding Diagnostics}" Visibility="{Binding Diagnostics.IsPopOut, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            <Border Visibility="{Binding Diagnostics.IsPopOut, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource CardStyle}" BorderBrush="{DynamicResource AppAccent}" BorderThickness="1" Height="200" VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{DynamicResource AppSecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="Đang hiển thị trong cửa sổ riêng." FontSize="11" Foreground="{DynamicResource AppSecondaryText}" HorizontalAlignment="Center"/>
                                    <Button Content="Gắn lại bảng điều khiển" Command="{Binding ReturnDiagnosticsCommand}" Style="{StaticResource AccentButtonStyle}" Margin="0,15,0,0" Width="180"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ PAGE: Thông tin ═══ -->
                        <StackPanel x:Name="PageAbout">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Thông tin" FontSize="17" FontWeight="Bold" Margin="0,0,0,6"/>
                            
                            <Border Style="{StaticResource CardStyle}" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Top Section: Logo & Brand -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="48" Height="48" Background="{DynamicResource AppControlBackground}" CornerRadius="10" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Margin="0,0,15,0">
                                            <Image Source="/Assets/VNKey.png" Margin="6"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="VNKey" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" Margin="0,0,0,0"/>
                                            <TextBlock Text="Phiên bản 2.0.0 Stable" FontSize="11" Foreground="{DynamicResource AppSecondaryText}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Description Area -->
                                    <Border Grid.Row="1" Background="{DynamicResource AppBackground}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                        <TextBlock Text="Bộ gõ tiếng Việt hiệu năng cao, mã nguồn mở và khả năng tùy biến tuyệt vời cho trải nghiệm gõ mượt mà." 
                                                   TextWrapping="Wrap" FontSize="11" LineHeight="16" Foreground="{DynamicResource AppText}" Opacity="0.9"/>
                                    </Border>

                                    <!-- Resource Links -->
                                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                        <TextBlock Text="TÀI NGUYÊN" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AppSecondaryText}" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- GitHub Link -->
                                            <Button Cursor="Hand" Background="Transparent" BorderThickness="0" Margin="0,0,15,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xEC40;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource AppAccent}"/>
                                                    <TextBlock Text="GitHub" FontSize="10" VerticalAlignment="Center" Foreground="{DynamicResource AppText}"/>
                                                </StackPanel>
                                            </Button>
                                            <!-- Website Link -->
                                            <Button Cursor="Hand" Background="Transparent" BorderThickness="0" Margin="0,0,15,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource AppAccent}"/>
                                                    <TextBlock Text="Trang chủ" FontSize="10" VerticalAlignment="Center" Foreground="{DynamicResource AppText}"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Footer info -->
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" Padding="0,8,0,0">
                                        <Grid>
                                            <TextBlock Text="© 2026 VNKey." FontSize="9" Foreground="{DynamicResource AppSecondaryText}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Phát triển bởi Van Quoc Bui" HorizontalAlignment="Right" FontSize="9" Foreground="{DynamicResource AppSecondaryText}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ═══ Bottom Bar ═══ -->
            <Grid Grid.Row="3" Margin="20,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding ResetCommand}" Style="{DynamicResource AppButtonStyle}" Width="95" Height="26" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="-1" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="Mặc định" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource AppButtonStyle}" Width="80" Height="26" Click="ExitButton_Click" Margin="0,0,8,0">
                        <TextBlock Text="Thoát" FontSize="11" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}" Width="80" Height="26" Click="CloseButton_Click">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đóng" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
