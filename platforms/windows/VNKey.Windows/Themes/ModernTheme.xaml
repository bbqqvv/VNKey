<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Design Tokens -->
    <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AppControlBackground" Color="#252526"/>
    <SolidColorBrush x:Key="AppAccent" Color="#00B7C3"/>
    <SolidColorBrush x:Key="AppBorder" Color="#3E3E42"/>
    <SolidColorBrush x:Key="AppText" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="AppSecondaryText" Color="#969696"/>
    <SolidColorBrush x:Key="AppButtonBackground" Color="#333333"/>
    <SolidColorBrush x:Key="AppButtonHoverBackground" Color="#3F3F46"/>
    <SolidColorBrush x:Key="AppAccentForeground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AppAccentHoverBackground" Color="#80F2FF"/>
    <SolidColorBrush x:Key="AppCardBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="AppScrollbarThumb" Color="#00E5FF"/>
    <SolidColorBrush x:Key="AppInputBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AppInputForeground" Color="White"/>
    <SolidColorBrush x:Key="AppAlternatingRow" Color="#05FFFFFF"/>

    <!-- Card style -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppCardBackground}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Global text styles -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
        <Setter Property="Margin" Value="0,6"/>
    </Style>
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
    </Style>

    <!-- Slim Scrollbar Style -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="3"/>
        <Setter Property="MinWidth" Value="3"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb>
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="{DynamicResource AppScrollbarThumb}" CornerRadius="2" Opacity="0.7"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Thumb.Style>
                            </Thumb>
                        </Track.Thumb>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
